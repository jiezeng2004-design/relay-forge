# RelayForge v0.3.0 — Environment Configuration
#
# Copy this file to .env and edit values as needed.
# RELAYFORGE_* variables are recommended. OPENRELAY_* / RELAY_* are
# kept as backward-compatible aliases.

# ----- Service -----

# Port for the local relay. Default: 18765
RELAYFORGE_PORT=18765

# Local relay token for API authentication.
# Clients use this as their API Key (Bearer token).
RELAYFORGE_TOKEN=

# Backward-compatible token aliases (optional, kept for existing setups)
# RELAY_TOKEN=
# OPENRELAY_TOKEN=

# Explicit unsafe mode — NOT recommended for normal use.
# When enabled, /v1/* and /admin/* do NOT require a token.
# RELAYFORGE_ALLOW_NO_AUTH=false

# ----- Upstream provider API keys -----
# Set the environment variable that each provider's keyEnv references.
# Multiple keys can be separated by commas.

OPENAI_API_KEYS=
ANTHROPIC_API_KEYS=
DEEPSEEK_API_KEYS=
MOONSHOT_API_KEYS=
GROQ_API_KEYS=
OPENROUTER_API_KEYS=
GEMINI_API_KEYS=
MISTRAL_API_KEYS=
SILICONFLOW_API_KEYS=
ZHIPU_API_KEYS=
COHERE_API_KEYS=
XAI_API_KEYS=
TOGETHER_API_KEYS=
VOLCENGINE_API_KEYS=
CEREBRAS_API_KEYS=
SAMBANOVA_API_KEYS=

# Local providers (Ollama, LM Studio, vLLM, llama.cpp) usually do not
# need API keys. They connect to localhost by default.
