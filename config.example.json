{
  "defaultProvider": "ollama",
  "modelAliases": {
    "gpt-4": "openai:gpt-4.1-mini",
    "fast-local": "unlimited-local"
  },
  "combos": [
    {
      "name": "smart-coding",
      "description": "Smart coding: DeepSeek primary, Groq cheap backup, Ollama local fallback",
      "strategy": "fallback",
      "candidates": [
        { "provider": "deepseek", "model": "deepseek-chat", "weight": 3, "priority": 2, "enabled": true },
        { "provider": "groq", "model": "llama-3.1-8b-instant", "weight": 2, "priority": 1, "enabled": true },
        { "provider": "ollama", "model": "qwen2.5:7b", "weight": 1, "priority": 0, "enabled": true }
      ]
    },
    {
      "name": "free-tier",
      "description": "Round-robin across free-tier providers",
      "strategy": "round_robin",
      "candidates": [
        { "provider": "groq", "model": "llama-3.1-8b-instant", "weight": 1, "enabled": true },
        { "provider": "gemini", "model": "gemini-2.0-flash", "weight": 1, "enabled": true }
      ]
    },
    {
      "name": "weighted-pool",
      "description": "Weighted round-robin: most requests to preferred provider",
      "strategy": "weighted_round_robin",
      "candidates": [
        { "provider": "deepseek", "model": "deepseek-chat", "weight": 5, "enabled": true },
        { "provider": "siliconflow", "model": "Qwen/Qwen2.5-7B-Instruct", "weight": 2, "enabled": true },
        { "provider": "ollama", "model": "qwen2.5:7b", "weight": 1, "enabled": true }
      ]
    }
  ],
  "providers": [
    {
      "name": "ollama",
      "baseUrl": "http://127.0.0.1:11434/v1",
      "keyEnv": null,
      "models": ["qwen2.5:7b", "llama3.1:8b"]
    },
    {
      "name": "lm-studio",
      "baseUrl": "http://127.0.0.1:1234/v1",
      "keyEnv": null,
      "models": ["local-model"]
    },
    {
      "name": "vllm",
      "baseUrl": "http://127.0.0.1:8000/v1",
      "keyEnv": null,
      "models": ["local-model"]
    },
    {
      "name": "llama-cpp",
      "baseUrl": "http://127.0.0.1:8080/v1",
      "keyEnv": null,
      "models": ["local-model"]
    },
    {
      "name": "llamafile",
      "baseUrl": "http://127.0.0.1:8080/v1",
      "keyEnv": null,
      "models": ["local-model"]
    },
    {
      "name": "deepseek",
      "baseUrl": "https://api.deepseek.com/v1",
      "keyEnv": "DEEPSEEK_API_KEYS",
      "models": ["deepseek-chat", "deepseek-reasoner"]
    },
    {
      "name": "openai",
      "baseUrl": "https://api.openai.com/v1",
      "keyEnv": "OPENAI_API_KEYS",
      "models": ["gpt-4.1-mini", "gpt-4o-mini"]
    },
    {
      "name": "moonshot",
      "baseUrl": "https://api.moonshot.cn/v1",
      "keyEnv": "MOONSHOT_API_KEYS",
      "models": ["moonshot-v1-8k", "moonshot-v1-32k"]
    },
    {
      "name": "anthropic",
      "baseUrl": "https://api.anthropic.com/v1",
      "keyEnv": "ANTHROPIC_API_KEYS",
      "apiFormat": "anthropic",
      "models": ["claude-3-5-haiku-latest", "claude-sonnet-4-20250514"]
    },
    {
      "name": "groq",
      "baseUrl": "https://api.groq.com/openai/v1",
      "keyEnv": "GROQ_API_KEYS",
      "models": ["llama-3.1-8b-instant", "llama-3.3-70b-versatile"]
    },
    {
      "name": "openrouter",
      "baseUrl": "https://openrouter.ai/api/v1",
      "keyEnv": "OPENROUTER_API_KEYS",
      "models": ["openrouter/auto", "deepseek/deepseek-chat-v3-0324"]
    },
    {
      "name": "gemini",
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
      "keyEnv": "GEMINI_API_KEYS",
      "models": ["gemini-2.0-flash", "gemini-1.5-flash"]
    },
    {
      "name": "mistral",
      "baseUrl": "https://api.mistral.ai/v1",
      "keyEnv": "MISTRAL_API_KEYS",
      "models": ["mistral-small-latest", "codestral-latest"]
    },
    {
      "name": "siliconflow",
      "baseUrl": "https://api.siliconflow.cn/v1",
      "keyEnv": "SILICONFLOW_API_KEYS",
      "models": ["Qwen/Qwen2.5-7B-Instruct", "deepseek-ai/DeepSeek-V3"]
    },
    {
      "name": "zhipu",
      "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
      "keyEnv": "ZHIPU_API_KEYS",
      "models": ["glm-4-flash", "glm-4-plus"]
    },
    {
      "name": "cohere",
      "baseUrl": "https://api.cohere.com/compatibility/v1",
      "keyEnv": "COHERE_API_KEYS",
      "models": ["command-r-plus", "command-r"]
    },
    {
      "name": "xai",
      "baseUrl": "https://api.x.ai/v1",
      "keyEnv": "XAI_API_KEYS",
      "models": ["grok-2-latest", "grok-2-mini"]
    },
    {
      "name": "together",
      "baseUrl": "https://api.together.xyz/v1",
      "keyEnv": "TOGETHER_API_KEYS",
      "models": ["meta-llama/Llama-3.3-70B-Instruct-Turbo", "Qwen/Qwen2.5-7B-Instruct-Turbo"]
    }
  ],
  "routes": [
    {
      "name": "coding-local",
      "description": "Prefer owned coding APIs, then fall back to local Ollama",
      "strategy": "fallback",
      "candidates": [
        { "provider": "deepseek", "model": "deepseek-chat", "weight": 3 },
        { "provider": "moonshot", "model": "moonshot-v1-8k", "weight": 1 },
        { "provider": "ollama", "model": "qwen2.5:7b", "weight": 1 }
      ]
    },
    {
      "name": "offline-local",
      "description": "Use local models only",
      "strategy": "round_robin",
      "candidates": [
        { "provider": "ollama", "model": "qwen2.5:7b" },
        { "provider": "ollama", "model": "llama3.1:8b" }
      ]
    },
    {
      "name": "unlimited-local",
      "description": "Local Ollama-only route; the local relay does not actively limit call count, but upstream limits still apply",
      "strategy": "round_robin",
      "candidates": [
        { "provider": "ollama", "model": "qwen2.5:7b" },
        { "provider": "ollama", "model": "llama3.1:8b" }
      ]
    },
    {
      "name": "balanced-local",
      "description": "Weighted route across configured providers",
      "strategy": "weighted",
      "candidates": [
        { "provider": "deepseek", "model": "deepseek-chat", "weight": 5 },
        { "provider": "moonshot", "model": "moonshot-v1-8k", "weight": 2 },
        { "provider": "ollama", "model": "qwen2.5:7b", "weight": 1 }
      ]
    },
    {
      "name": "free-api-pool",
      "description": "Manual BYOK route for providers with free tiers",
      "strategy": "weighted",
      "candidates": [
        { "provider": "groq", "model": "llama-3.1-8b-instant", "weight": 4 },
        { "provider": "gemini", "model": "gemini-2.0-flash", "weight": 3 },
        { "provider": "siliconflow", "model": "Qwen/Qwen2.5-7B-Instruct", "weight": 2 },
        { "provider": "ollama", "model": "qwen2.5:7b", "weight": 1 }
      ]
    }
  ],
  "activeProfile": "local-only",
  "profiles": [
    {
      "name": "local-only",
      "description": "Use local Ollama models only; no cloud key required",
      "defaultModel": "unlimited-local"
    },
    {
      "name": "coding",
      "description": "Prefer coding APIs, then fall back to local Ollama",
      "defaultModel": "coding-local"
    },
    {
      "name": "free-tier-pool",
      "description": "Use configured free-tier or BYOK providers with local fallback",
      "defaultModel": "free-api-pool"
    }
  ],
  "retry": {
    "maxAttempts": 3,
    "cooldownMs": 30000,
    "timeoutMs": 120000,
    "streamIdleTimeoutMs": 300000
  },
  "limits": {
    "maxBodyBytes": 10485760,
    "dailyRequests": null,
    "providers": {},
    "routes": {},
    "models": {}
  },
  "history": {
    "retentionDays": 14
  },
  "healthChecks": {
    "enabled": false,
    "intervalMinutes": 60,
    "providers": []
  },
  "privacy": {
    "logPrompts": false,
    "logHeaders": false
  }
}
